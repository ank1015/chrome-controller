{
  "manifest_version": 3,
  "name": "ank1015-llm-extension",
  "version": "0.1",
  "description": "Connect Chrome to LLM agents so they can inspect pages, automate browser tasks, and control tabs through a native bridge.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "nativeMessaging",
    "scripting",
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "downloads",
    "debugger",
    "accessibilityFeatures.read",
    "accessibilityFeatures.modify"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
